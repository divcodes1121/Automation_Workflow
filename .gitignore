# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments (any name, any depth — incl. experiments/kokoro/.venv312)
.venv*/
venv/
env/

# Environment / secrets
.env
.env.*
!.env.example

# Hugging Face / model caches accidentally placed in-repo
**/hf_cache/
**/.cache/

# OS
.DS_Store
Thumbs.db

# Analyzer template cache (derived; rebuild via `python -m analyzer.main build-templates`)
analyzer/cache/

# Gameplay media (user recordings / large; keep out of git)
gameplay/**/*.mp4
gameplay/**/*.mov
gameplay/**/*.mkv
gameplay/**/*.webm
gameplay/archive/
gameplay/processed/
gameplay/shorts/
gameplay/analysis/

# Meme asset library (user-managed third-party SFX/images; licensing varies -
# kept local like gameplay footage; recipes reference these by filename)
Memes/**/*.mp3
Memes/**/*.wav
Memes/**/*.ogg
Memes/**/*.png
Memes/**/*.jpg
Memes/**/*.jpeg
Memes/**/*.gif
Memes/**/*.webp
Memes/**/*.mp4
Memes/**/*.webm
Memes/**/*.mov
Memes/cache/

# Generated pipeline outputs (regenerated by the F1-F11 commands)
edited/
backend/output/
voice/
uploads/
scripts/
logs/

# Secrets / OAuth tokens
config/*.json
config/*token*
config/*secret*

# Experiment spikes: model weights / audio / caches (keep source .py only)
experiments/**/*.wav
experiments/**/*.pt
experiments/**/*.pth
experiments/**/*.onnx
experiments/**/models/

# Asset Manager: auto-downloaded third-party assets + index (regenerable via
# `python -m asset_manager.main sync`). Licensing varies per source; not vendored.
/assets/audio/
/assets/gifs/
/assets/stickers/
/assets/icons/
/assets/particles/
/assets/overlays/
/assets/luts/
/assets/transitions/
/assets/comic/
/assets/camera/
/assets/_cache/
/assets/asset_manifest.json
/assets/asset_index.db
/assets/asset_index.db-*
